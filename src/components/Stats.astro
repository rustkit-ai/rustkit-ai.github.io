---
const facts = [
  {
    value: '90%',
    label: 'fewer tokens',
    desc: 'trimcp compresses MCP tool outputs by 60–90% before they reach your LLM — tersify cuts another 50% on top.',
  },
  {
    value: '5',
    label: 'languages',
    desc: 'semtree parses and indexes Rust, Python, JavaScript, TypeScript, and Go with tree-sitter.',
  },
  {
    value: '4',
    label: 'AI editors',
    desc: 'aimemo works with Claude Code, Cursor, Windsurf, and GitHub Copilot — out of the box, zero configuration.',
  },
  {
    value: '5',
    label: 'open source tools',
    desc: 'tersify, aimemo, semtree, semstore, and trimcp — all MIT licensed, all on crates.io.',
  },
];
---

<section class="stats">
  <div class="section-inner">
    <div class="section-label reveal">By the numbers</div>
    <h2 class="reveal">Built to perform</h2>
    <p class="section-sub reveal">No benchmarks against imaginary competitors — just what our tools actually do.</p>

    <div class="facts-grid">
      {facts.map((f) => (
        <div class="fact-item reveal">
          <div class="fact-value">{f.value}</div>
          <div class="fact-label">{f.label}</div>
          <p class="fact-desc">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    background: var(--bg-2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .facts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0;
    margin-top: 3rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .fact-item {
    padding: 2rem 1.75rem;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: background 0.2s;
  }

  .fact-item:hover { background: var(--bg-3); }

  .fact-value {
    font-family: 'Space Mono', monospace;
    font-size: 2rem;
    font-weight: 700;
    color: var(--rust);
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 0.3rem;
  }

  .fact-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .fact-desc {
    font-size: 0.83rem;
    color: var(--text-muted);
    line-height: 1.65;
  }
</style>
