---
---

<nav id="nav">
  <a href="/" class="nav-logo">rustkit<span>.</span>ai</a>
  <ul class="nav-links" id="nav-links">
    <li><a href="/#projects">Projects</a></li>
    <li><a href="/team">Team</a></li>
    <li>
      <a href="/search" class="nav-search" aria-label="Search">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </a>
    </li>
    <li>
      <a href="https://github.com/rustkit-ai" target="_blank" rel="noopener" class="nav-gh">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </li>
  </ul>
  <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1.25rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s, background 0.3s;
  }

  nav.scrolled {
    background: rgba(14, 13, 12, 0.92);
    backdrop-filter: blur(12px);
    border-color: var(--border);
  }

  .nav-logo {
    font-family: 'Space Mono', monospace;
    font-size: 0.95rem;
    color: var(--text);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .nav-logo span { color: var(--rust); }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--text); }

  .nav-gh {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.78rem;
    color: var(--rust) !important;
    border: 1px solid var(--rust-dim);
    padding: 0.4rem 0.85rem;
    border-radius: 3px;
    transition: background 0.2s !important;
  }

  .nav-gh:hover { background: var(--rust-glow); }

  .nav-search {
    display: flex;
    align-items: center;
    padding: 0.4rem;
    color: var(--text-dim) !important;
    border: none !important;
    transition: color 0.2s !important;
  }

  .nav-search:hover { color: var(--text) !important; }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
  }

  .hamburger span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--text-muted);
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  @media (max-width: 640px) {
    nav { padding: 1rem 1.25rem; }

    .hamburger { display: flex; }

    .nav-links {
      display: none;
      position: fixed;
      top: 57px;
      left: 0;
      right: 0;
      background: rgba(14, 13, 12, 0.97);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      flex-direction: column;
      gap: 0;
      padding: 0.5rem 0;
    }

    .nav-links.open { display: flex; }

    .nav-links li { width: 100%; }

    .nav-links a {
      display: block;
      padding: 0.9rem 1.25rem;
      border-bottom: 1px solid var(--border);
      font-size: 0.9rem;
    }

    .nav-links li:last-child a { border-bottom: none; }

    .nav-gh {
      border: none !important;
      border-radius: 0 !important;
      padding: 0.9rem 1.25rem !important;
    }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  const hamburger = document.getElementById('hamburger');
  const navLinks = document.getElementById('nav-links');

  hamburger?.addEventListener('click', () => {
    const open = hamburger.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(open));
    navLinks?.classList.toggle('open', open);
  });

  navLinks?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      hamburger?.classList.remove('open');
      hamburger?.setAttribute('aria-expanded', 'false');
      navLinks.classList.remove('open');
    });
  });
</script>
