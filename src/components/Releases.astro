---
import { projects } from '../data/projects';
import { ghFetch } from '../lib/github';

type Release = {
  tag_name: string;
  name: string;
  published_at: string | null;
  html_url: string;
};

type ProjectRelease = {
  slug: string;
  github: string;
  release: Release;
};

const releaseProjects = projects.filter((p) => p.hasReleases);

const results = await Promise.all(
  releaseProjects.map(async (p) => {
    try {
      const res = await ghFetch(`repos/rustkit-ai/${p.slug}/releases`);
      const data: Release[] = await res.json();
      const latest = data
        .filter((r) => r.published_at)
        .sort((a, b) => new Date(b.published_at!).getTime() - new Date(a.published_at!).getTime())[0];
      return latest ? { slug: p.slug, github: p.github, release: latest } : null;
    } catch {
      return null;
    }
  })
);

const releases: ProjectRelease[] = results
  .filter((r): r is ProjectRelease => r !== null)
  .sort((a, b) =>
    new Date(b.release.published_at!).getTime() - new Date(a.release.published_at!).getTime()
  );

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<section id="releases">
  <div class="section-inner">
    <div class="section-label reveal">Changelog</div>
    <h2 class="reveal">Latest releases</h2>
    <p class="section-sub reveal">Recent updates across our open source projects.</p>

    <div class="releases-list reveal">
      {releases.length === 0 ? (
        <p class="releases-empty">No releases found.</p>
      ) : (
        releases.map((item) => (
          <a href={item.release.html_url} target="_blank" rel="noopener" class="release-item">
            <div class="release-left">
              <span class="release-project">{item.slug}</span>
              <span class="release-tag">{item.release.tag_name}</span>
              <span class="release-badge">Latest</span>
            </div>
            <div class="release-name">{item.release.name}</div>
            <div class="release-date">{formatDate(item.release.published_at!)}</div>
            <span class="release-arrow">→</span>
          </a>
        ))
      )}
    </div>

    {releases.length > 0 && (
      <div class="all-links reveal">
        {releases.map((item) => (
          <a href={`${item.github}/releases`} target="_blank" rel="noopener" class="all-releases">
            All {item.slug} releases →
          </a>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .releases-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }

  .release-item {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--border);
    background: var(--bg-2);
    transition: background 0.2s;
  }

  .release-item:last-child { border-bottom: none; }
  .release-item:hover { background: var(--bg-3); }

  .release-left {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .release-project {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .release-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .release-badge {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.62rem;
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    background: var(--rust-glow);
    color: var(--rust);
    border: 1px solid var(--rust-dim);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .release-name {
    font-size: 0.88rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .release-date {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-dim);
    white-space: nowrap;
  }

  .release-arrow {
    color: var(--text-dim);
    font-size: 0.85rem;
    transition: transform 0.2s, color 0.2s;
  }

  .release-item:hover .release-arrow {
    transform: translateX(3px);
    color: var(--rust);
  }

  .all-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .all-releases {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.78rem;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
  }

  .all-releases:hover { color: var(--rust); }

  .releases-empty {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.8rem;
    color: var(--text-dim);
    padding: 1.5rem;
    text-align: center;
  }

  @media (max-width: 640px) {
    .release-item {
      grid-template-columns: auto 1fr auto;
      gap: 0.6rem;
    }
    .release-name { display: none; }
  }
</style>
