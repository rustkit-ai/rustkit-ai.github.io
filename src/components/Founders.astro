---
const founders = [
  {
    name: 'Djamel Bougouffa',
    handle: 'Strawbang',
    github: 'https://github.com/Strawbang',
    linkedin: 'https://www.linkedin.com/in/djamel-bougouffa/',
    website: 'https://djamel-bougouffa.com/',
    twitter: null,
  },
  {
    name: 'Gokhan Kabar',
    handle: 'GokhanKabar',
    github: 'https://github.com/GokhanKabar',
    linkedin: 'https://www.linkedin.com/in/gokhan-kabar/',
    website: 'https://gokhankabar.com/',
    twitter: null,
  },
];
---

<section id="founders">
  <div class="section-inner">
    <div class="section-label reveal">Team</div>
    <h2 class="reveal">The founders</h2>
    <p class="section-sub reveal">Two engineers obsessed with making AI-assisted development faster and cheaper.</p>

    <div class="founders-grid">
      {founders.map((f) => (
        <div class="founder-card reveal">
          <div class="founder-avatar">
            <img
              src={`https://github.com/${f.handle}.png`}
              alt={f.name}
              onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
            />
            <span class="avatar-fallback" style="display:none">
              {f.name.split(' ').map((n: string) => n[0]).join('')}
            </span>
          </div>
          <div class="founder-info">
            <div class="founder-name">{f.name}</div>
            <div class="founder-handle">@{f.handle}</div>
            <div class="founder-links">
              <a href={f.github} target="_blank" rel="noopener" aria-label="GitHub">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                </svg>
              </a>
              {f.linkedin && (
                <a href={f.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              )}
              {f.twitter && (
                <a href={f.twitter} target="_blank" rel="noopener" aria-label="Twitter / X">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.63L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                </a>
              )}
              {f.website && (
                <a href={f.website} target="_blank" rel="noopener" aria-label="Website">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .founders-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .founder-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.75rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .founder-card:hover {
    border-color: var(--rust-dim);
    background: var(--bg-3);
  }

  .founder-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 2px solid var(--border-hi);
    overflow: hidden;
    flex-shrink: 0;
    background: var(--bg-3);
    position: relative;
  }

  .founder-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .avatar-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Space Mono', monospace;
    font-size: 1rem;
    color: var(--rust);
  }

  .founder-name {
    font-family: 'Space Mono', monospace;
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.15rem;
  }

  .founder-handle {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    color: var(--rust);
    margin-bottom: 0.75rem;
  }

  .founder-links {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .founder-links a {
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }

  .founder-links a:hover { color: var(--text); }
</style>
