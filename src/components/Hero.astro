---
---

<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-glow"></div>
  <div class="hero-inner">
    <div class="hero-tag">Open Source · Built in Rust</div>
    <h1>
      Make your AI agents
      <span class="dim">smarter<span class="accent">.</span> cheaper<span class="accent">.</span></span>
    </h1>
    <p class="hero-sub">
      Persistent memory, token-cost reduction, and semantic search —
      three Rust tools built for the reality of AI-assisted development.
    </p>

    <div class="install-block">
      <span class="install-prompt">$</span>
      <code id="install-cmd">cargo install memo</code>
      <button class="copy-btn" id="copy-btn" aria-label="Copy install command">
        <svg id="icon-copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
        </svg>
        <svg id="icon-check" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </button>
    </div>

    <div class="hero-actions">
      <a href="#projects" class="btn-primary">
        Explore projects
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
      <a href="https://github.com/rustkit-ai" target="_blank" rel="noopener" class="btn-ghost">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        github.com/rustkit-ai
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 8rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 30%, transparent 80%);
    opacity: 0.4;
  }

  .hero-glow {
    position: absolute;
    top: 30%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(ellipse, #e8591a18 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    max-width: 900px;
    margin: 0 auto;
    width: 100%;
    position: relative;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.75rem;
    color: var(--rust);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.6s ease forwards 0.1s;
  }

  .hero-tag::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--rust);
  }

  h1 {
    font-family: 'Space Mono', monospace;
    font-size: clamp(2.4rem, 6vw, 4.8rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.04em;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.2s;
  }

  h1 .accent { color: var(--rust); }
  h1 .dim { color: var(--text-dim); display: block; }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 500px;
    line-height: 1.75;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.35s;
  }

  /* Install block */
  .install-block {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--bg-2);
    border: 1px solid var(--border-hi);
    border-radius: 4px;
    padding: 0.7rem 1rem;
    margin-bottom: 2rem;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.45s;
  }

  .install-prompt {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85rem;
    color: var(--rust);
    user-select: none;
  }

  .install-block code {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85rem;
    color: var(--text);
  }

  .copy-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    padding: 0.15rem;
    border-radius: 3px;
    transition: color 0.2s;
    margin-left: 0.25rem;
  }

  .copy-btn:hover { color: var(--text); }
  .copy-btn.copied { color: #4caf50; }

  /* Actions */
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.7s ease forwards 0.55s;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--rust);
    color: #fff;
    text-decoration: none;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    border-radius: 3px;
    transition: background 0.2s, transform 0.15s;
    letter-spacing: 0.02em;
  }

  .btn-primary:hover { background: #c94a12; transform: translateY(-1px); }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: transparent;
    color: var(--text-muted);
    text-decoration: none;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85rem;
    padding: 0.75rem 1.5rem;
    border-radius: 3px;
    border: 1px solid var(--border-hi);
    transition: color 0.2s, border-color 0.2s;
    letter-spacing: 0.02em;
  }

  .btn-ghost:hover { color: var(--text); border-color: var(--text-dim); }

  @media (max-width: 640px) {
    .hero { padding: 6rem 1.25rem 3rem; }
    .install-block { width: 100%; }
  }
</style>

<script>
  const btn = document.getElementById('copy-btn');
  const iconCopy = document.getElementById('icon-copy');
  const iconCheck = document.getElementById('icon-check');

  btn?.addEventListener('click', () => {
    navigator.clipboard.writeText('cargo install memo');
    btn.classList.add('copied');
    iconCopy!.style.display = 'none';
    iconCheck!.style.display = 'block';
    setTimeout(() => {
      btn.classList.remove('copied');
      iconCopy!.style.display = 'block';
      iconCheck!.style.display = 'none';
    }, 2000);
  });
</script>
