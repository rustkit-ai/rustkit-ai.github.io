---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const founders = [
  {
    name: 'Djamel Bougouffa',
    handle: 'Strawbang',
    role: 'Co-founder',
    bio: 'Software engineer building open source developer tools in Rust. Focused on making AI-assisted development faster and more affordable.',
    github: 'https://github.com/Strawbang',
    linkedin: 'https://www.linkedin.com/in/djamel-bougouffa/',
    website: 'https://djamel-bougouffa.com/',
    twitter: null,
  },
  {
    name: 'Gokhan Kabar',
    handle: 'GokhanKabar',
    role: 'Co-founder',
    bio: 'Software engineer with a passion for systems programming and developer tooling. Building the infrastructure layer for AI-native workflows.',
    github: 'https://github.com/GokhanKabar',
    linkedin: 'https://www.linkedin.com/in/gokhan-kabar/',
    website: 'https://gokhankabar.com/',
    twitter: null,
  },
];
---

<Layout
  title="Team — rustkit-ai"
  description="Meet the founders of rustkit-ai, building AI-native developer tools in Rust."
>
  <Nav />

  <main class="team-page">
    <div class="page-inner">
      <div class="page-header">
        <div class="page-tag">Team</div>
        <h1>The founders</h1>
        <p class="page-sub">Two engineers building tools they wish existed.</p>
      </div>

      <div class="founders-grid">
        {founders.map((f) => (
          <div class="founder-card">
            <div class="card-photo">
              <img
                src={`https://github.com/${f.handle}.png`}
                alt={f.name}
                onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
              />
              <div class="photo-fallback">
                {f.name.split(' ').map((n: string) => n[0]).join('')}
              </div>
            </div>

            <div class="card-body">
              <div class="card-meta">
                <h2>{f.name}</h2>
                <span class="card-role">{f.role}</span>
              </div>
              <div class="card-handle">@{f.handle}</div>

              {f.bio && <p class="card-bio">{f.bio}</p>}

              <div class="card-links">
                <a href={f.github} target="_blank" rel="noopener" class="link-pill">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
                  </svg>
                  GitHub
                </a>
                <a href={f.linkedin} target="_blank" rel="noopener" class="link-pill">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  LinkedIn
                </a>
                <a href={f.website} target="_blank" rel="noopener" class="link-pill">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
                  </svg>
                  Website
                </a>
                {f.twitter && (
                  <a href={f.twitter} target="_blank" rel="noopener" class="link-pill">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.63L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                    </svg>
                    Twitter
                  </a>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .team-page {
    min-height: 100vh;
    padding: 8rem 2rem 4rem;
  }

  .page-inner {
    max-width: 900px;
    margin: 0 auto;
  }

  .page-header {
    margin-bottom: 4rem;
  }

  .page-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.75rem;
    color: var(--rust);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .page-tag::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--rust);
  }

  h1 {
    font-family: 'Space Mono', monospace;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-bottom: 0.75rem;
  }

  .page-sub {
    font-size: 1rem;
    color: var(--text-muted);
  }

  .founders-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 1.5rem;
  }

  .founder-card {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s;
  }

  .founder-card:hover { border-color: var(--rust-dim); }

  .card-body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
    flex: 1;
  }

  .card-photo {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--bg-3);
    border: 2px solid var(--border-hi);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-bottom: 0.75rem;
  }

  .card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .photo-fallback {
    display: none;
    position: absolute;
    inset: 0;
    align-items: center;
    justify-content: center;
    font-family: 'Space Mono', monospace;
    font-size: 1.2rem;
    color: var(--rust);
    background: var(--bg-3);
  }

  .card-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  h2 {
    font-family: 'Space Mono', monospace;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .card-role {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    color: var(--rust);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px solid var(--rust-dim);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }

  .card-handle {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.78rem;
    color: var(--text-dim);
    margin-bottom: 0.5rem;
  }

  .card-bio {
    font-size: 0.88rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }

  .card-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .link-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-muted);
    text-decoration: none;
    border: 1px solid var(--border-hi);
    padding: 0.35rem 0.7rem;
    border-radius: 3px;
    transition: color 0.2s, border-color 0.2s;
  }

  .link-pill:hover {
    color: var(--text);
    border-color: var(--text-dim);
  }

  @media (max-width: 640px) {
    .team-page { padding: 6rem 1.25rem 3rem; }
    .founders-grid { grid-template-columns: 1fr; }
  }
</style>
