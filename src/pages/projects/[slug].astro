---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { projects } from '../../data/projects';
import { marked } from 'marked';
import { ghFetch } from '../../lib/github';

type Release = {
  tag_name: string;
  name: string;
  published_at: string | null;
  html_url: string;
};

export async function getStaticPaths() {
  async function fetchReleases(slug: string): Promise<Release[]> {
    try {
      const res = await ghFetch(`repos/rustkit-ai/${slug}/releases`);
      const data: Release[] = await res.json();
      return data
        .filter((r) => r.published_at)
        .sort((a, b) => new Date(b.published_at!).getTime() - new Date(a.published_at!).getTime());
    } catch {
      return [];
    }
  }

  async function fetchReadme(slug: string): Promise<string> {
    try {
      const res = await fetch(`https://raw.githubusercontent.com/rustkit-ai/${slug}/main/README.md`,
        import.meta.env.GITHUB_TOKEN ? { headers: { Authorization: `Bearer ${import.meta.env.GITHUB_TOKEN}` } } : {});
      if (!res.ok) return '';
      const md = await res.text();
      return marked(md) as string;
    } catch {
      return '';
    }
  }

  const results = await Promise.all(
    projects.map(async (p) => {
      const [releases, readme] = await Promise.all([
        p.hasReleases ? fetchReleases(p.slug) : Promise.resolve([]),
        fetchReadme(p.slug),
      ]);
      return { params: { slug: p.slug }, props: { project: p, releases, readme } };
    })
  );
  return results;
}

const { slug } = Astro.params;
const project = Astro.props.project ?? projects.find((p) => p.slug === slug)!;
const releases: Release[] = Astro.props.releases ?? [];
const readme: string = Astro.props.readme ?? '';

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<Layout
  title={`${project.name} — rustkit-ai`}
  description={project.description}
>
  <Nav />

  <main class="project-page" data-pagefind-body>
    <div class="page-inner">

      <!-- Header -->
      <div class="page-header">
        <a href="/#projects" class="back-link">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/>
          </svg>
          All projects
        </a>
        <div class="header-badges">
          <span class="badge badge-rust">{project.language}</span>
        </div>
        <h1>{project.name}</h1>
        <p class="page-sub">{project.description}</p>
        <div class="header-actions">
          {project.install && (
            <div class="install-block">
              <span class="install-prompt">$</span>
              <code id="install-cmd">{project.install}</code>
              <button class="copy-btn" id="copy-btn" aria-label="Copy">
                <svg id="icon-copy" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                </svg>
                <svg id="icon-check" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </button>
            </div>
          )}
          <a href={project.github} target="_blank" rel="noopener" class="btn-ghost">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            GitHub
          </a>
          {project.crates && (
            <a href={project.crates} target="_blank" rel="noopener" class="btn-ghost">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M21 7.5l-9-4.5-9 4.5v9l9 4.5 9-4.5v-9z"/>
              </svg>
              crates.io
            </a>
          )}
        </div>
      </div>

      <!-- README / Description -->
      <div class="section">
        {readme ? (
          <div class="readme-content" set:html={readme} />
        ) : (
          <div class="long-desc">
            {project.longDescription.split('\n\n').map((para) => (
              <p>{para}</p>
            ))}
          </div>
        )}
      </div>

      <!-- Releases -->
      {releases.length > 0 && (
        <div class="section">
          <div class="section-label">Releases</div>
          <div class="releases-list">
            {releases.map((r, i) => (
              <a href={r.html_url} target="_blank" rel="noopener" class={`release-item ${i === 0 ? 'latest' : ''}`}>
                <div class="release-left">
                  <span class="release-tag">{r.tag_name}</span>
                  {i === 0 && <span class="release-badge">Latest</span>}
                </div>
                <div class="release-name">{r.name}</div>
                <div class="release-date">{formatDate(r.published_at!)}</div>
                <span class="release-arrow">→</span>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </main>

  <Footer />
</Layout>

<style>
  .project-page {
    min-height: 100vh;
    padding: 7rem 2rem 4rem;
  }

  .page-inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.78rem;
    color: var(--text-dim);
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color 0.2s;
  }

  .back-link:hover { color: var(--rust); }

  .header-badges { margin-bottom: 1rem; }

  .badge {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    padding: 0.2rem 0.55rem;
    border-radius: 3px;
    letter-spacing: 0.04em;
  }

  .badge-rust { background: #e8591a18; color: #e87a4a; border: 1px solid #e8591a30; }

  h1 {
    font-family: 'Space Mono', monospace;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
  }

  .page-sub {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: 2rem;
  }

  .header-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .install-block {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--bg-2);
    border: 1px solid var(--border-hi);
    border-radius: 4px;
    padding: 0.65rem 1rem;
  }

  .install-prompt {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85rem;
    color: var(--rust);
    user-select: none;
  }

  .install-block code {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85rem;
    color: var(--text);
  }

  .copy-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    padding: 0.15rem;
    transition: color 0.2s;
  }

  .copy-btn:hover { color: var(--text); }
  .copy-btn.copied { color: #4caf50; }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: transparent;
    color: var(--text-muted);
    text-decoration: none;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85rem;
    padding: 0.65rem 1.25rem;
    border-radius: 4px;
    border: 1px solid var(--border-hi);
    transition: color 0.2s, border-color 0.2s;
  }

  .btn-ghost:hover { color: var(--text); border-color: var(--text-dim); }

  /* Section */
  .section { display: flex; flex-direction: column; gap: 1.5rem; }

  .section-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    color: var(--rust);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .long-desc {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .long-desc p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.8;
  }

  /* Releases */
  .releases-list {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
  }

  .release-item {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--border);
    background: var(--bg-2);
    transition: background 0.2s;
  }

  .release-item:last-child { border-bottom: none; }
  .release-item:hover { background: var(--bg-3); }
  .release-item.latest { background: var(--bg-3); }

  .release-left { display: flex; align-items: center; gap: 0.6rem; }

  .release-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    min-width: 60px;
  }

  .release-badge {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.62rem;
    padding: 0.15rem 0.45rem;
    border-radius: 3px;
    background: var(--rust-glow);
    color: var(--rust);
    border: 1px solid var(--rust-dim);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .release-name {
    font-size: 0.88rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .release-date {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.75rem;
    color: var(--text-dim);
    white-space: nowrap;
  }

  .release-arrow {
    color: var(--text-dim);
    font-size: 0.85rem;
    transition: transform 0.2s, color 0.2s;
  }

  .release-item:hover .release-arrow { transform: translateX(3px); color: var(--rust); }

  /* README rendered markdown */
  .readme-content :global(h1) { display: none; }

  .readme-content :global(h2) {
    font-family: 'Space Mono', monospace;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .readme-content :global(h3) {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
    margin: 1.75rem 0 0.75rem;
  }

  .readme-content :global(p) {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .readme-content :global(p:has(img)) { display: none; }

  .readme-content :global(a) {
    color: var(--rust);
    text-decoration: none;
  }

  .readme-content :global(a:hover) { text-decoration: underline; }

  .readme-content :global(code) {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.82rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.1em 0.4em;
    color: var(--text);
  }

  .readme-content :global(pre) {
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1.25rem 0;
  }

  .readme-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .readme-content :global(ul),
  .readme-content :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .readme-content :global(li) {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 0.25rem;
  }

  .readme-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.82rem;
    margin: 1.25rem 0;
  }

  .readme-content :global(th) {
    text-align: left;
    color: var(--text-dim);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-bottom: 1px solid var(--border);
    padding: 0.5rem 1rem;
  }

  .readme-content :global(td) {
    color: var(--text-muted);
    border-bottom: 1px solid var(--border);
    padding: 0.6rem 1rem;
  }

  .readme-content :global(blockquote) {
    border-left: 3px solid var(--rust-dim);
    padding-left: 1rem;
    margin: 1rem 0;
    color: var(--text-dim);
    font-size: 0.9rem;
  }

  .readme-content :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2rem 0;
  }

  @media (max-width: 640px) {
    .project-page { padding: 6rem 1.25rem 3rem; }
    .release-item { grid-template-columns: auto 1fr auto; }
    .release-name { display: none; }
  }
</style>

<script>
  const btn = document.getElementById('copy-btn');
  const cmd = document.getElementById('install-cmd');
  const iconCopy = document.getElementById('icon-copy');
  const iconCheck = document.getElementById('icon-check');

  btn?.addEventListener('click', () => {
    navigator.clipboard.writeText(cmd?.textContent ?? '');
    btn.classList.add('copied');
    iconCopy!.style.display = 'none';
    iconCheck!.style.display = 'block';
    setTimeout(() => {
      btn.classList.remove('copied');
      iconCopy!.style.display = 'block';
      iconCheck!.style.display = 'none';
    }, 2000);
  });
</script>
